# ── Clerk Authentication ──
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── Firebase ──
EXPO_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
EXPO_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# ── Google Gemini AI ──
EXPO_PUBLIC_GEMINI_API_KEY=REPLACE_ME

# ── FatSecret API (server-only — not bundled into the app) ──
FATSECRET_CLIENT_ID=REPLACE_ME
FATSECRET_CLIENT_SECRET=REPLACE_ME

# ── FatSecret (backwards compatibility) ──
EXPO_PUBLIC_FATSECRET_CLIENT_ID=REPLACE_ME
EXPO_PUBLIC_FATSECRET_CLIENT_SECRET=REPLACE_ME

# ── Food Search Proxy URL ──
# In development: Auto-detected from Expo's debugger host — no config needed!
# In production: Set this to your deployed backend URL, e.g.:
# EXPO_PUBLIC_PROXY_BASE_URL=https://your-proxy.example.com
